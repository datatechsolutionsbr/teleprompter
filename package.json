{
  "name": "@datatechsolutions/teleprompter",
  "version": "0.1.0",
  "description": "Drop-in React teleprompter — auto-scroll, mirror, section labels, keyboard control. Extracted from the Astrlabe / Datatech pitch deck.",
  "license": "MIT",
  "author": "Datatech Solutions",
  "homepage": "https://github.com/kori-app/teleprompter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kori-app/teleprompter.git"
  },
  "bugs": {
    "url": "https://github.com/kori-app/teleprompter/issues"
  },
  "keywords": [
    "teleprompter",
    "react",
    "pitch",
    "presentation",
    "scroll",
    "tailwindcss"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
