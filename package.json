{
  "name": "@datatechsolutions/teleprompter",
  "version": "0.3.0",
  "description": "Drop-in React teleprompter — voice-paced auto-scroll, mirror, section labels, keyboard control. Zero deps.",
  "license": "MIT",
  "author": "Datatech Solutions",
  "homepage": "https://github.com/datatechsolutionsbr/teleprompter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datatechsolutionsbr/teleprompter.git"
  },
  "bugs": {
    "url": "https://github.com/datatechsolutionsbr/teleprompter/issues"
  },
  "keywords": [
    "teleprompter",
    "react",
    "react-19",
    "pitch",
    "presentation",
    "scroll",
    "voice-recognition",
    "speech-recognition",
    "wpm",
    "tailwindcss"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
